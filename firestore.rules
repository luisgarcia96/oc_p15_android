rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return data.ownerUserId == request.auth.uid;
    }

    function validEventDocument(data) {
      return data.keys().hasAll([
          'id',
          'title',
          'description',
          'eventAt',
          'address',
          'imageUrl',
          'imagePath',
          'ownerUserId',
          'createdAt',
          'updatedAt'
        ]) &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        data.description.size() > 0 &&
        data.address is string &&
        data.address.size() > 0 &&
        data.eventAt is timestamp &&
        data.imageUrl is string &&
        data.imageUrl.size() > 0 &&
        data.imagePath is string &&
        data.imagePath.size() > 0 &&
        data.ownerUserId is string &&
        data.ownerUserId.size() > 0 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        isOwner(request.resource.data) &&
        validEventDocument(request.resource.data);
      allow update: if isSignedIn() &&
        isOwner(resource.data) &&
        isOwner(request.resource.data) &&
        validEventDocument(request.resource.data);
      allow delete: if isSignedIn() &&
        isOwner(resource.data);
    }
  }
}
